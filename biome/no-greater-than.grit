// Biome GritQL plugin: flag `>` and `>=` comparisons.
// GritQL plugins in Biome v2 are DETECTION-ONLY — they can report diagnostics
// but cannot apply fixes. The intended workflow here is "flag precisely, let an
// agent (or the ESLint rule) do the rewrite."

language js

or {
  `$left > $right`,
  `$left >= $right`
} where {
  register_diagnostic(
    span = $left,
    message = "Use `<` / `<=` so the comparison reads like a number line (flip the operands)."
  )
}
