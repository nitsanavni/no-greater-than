// Biome GritQL plugin: detect scrambled two-sided number-line ranges.
//
// Like `no-greater-than.grit`, this is DETECTION-ONLY and the message CANNOT
// interpolate the matched operands ($x prints literally ‚Äî verified). So we
// detect scrambled ranges that share a variable and teach the canonical shape
// with a STATIC template (not the actual operands at the site):
//   between (`&&`):  lo < x && x < hi
//   outside (`||`):  x < lo || hi < x
//
// We match ranges where the SAME middle variable $x appears on the "wrong" side
// of the comparison. The canonical between/outside shapes always read with the
// smaller bound on the LEFT and the larger on the RIGHT:
//   strict:    `lo < x && x < hi` / `x < lo || hi < x`
//   inclusive: `lo <= x && x <= hi` / `x <= lo || hi <= x`
//   half-open: `lo <= x && x < hi`, etc. ‚Äî also canonical when bounds stay
//              left/right ordered.
// A range is "scrambled" when a clause flips the bound onto the wrong side,
// i.e. it uses `>` or `>=` (x bigger than the low bound written on x's left),
// or it reorders the two clauses so the high-side test comes first. Canonical
// ranges never contain a `>`/`>=` and keep the bound-on-left ordering, so they
// are NOT matched. See README for the residual limitation.

language js

or {
  // ---------- STRICT between (`<` / `>`) ----------
  // between: `$x > $lo && $x < $hi`  (e.g. x > 1 && x < 10)
  `$x > $lo && $x < $hi` where {
    register_diagnostic(
      span = $x,
      message = "Order this range like a number line ‚Äî better: `lo < x && x < hi`"
    )
  },
  // between: `$x < $hi && $x > $lo`  (e.g. x < 10 && x > 1)
  `$x < $hi && $x > $lo` where {
    register_diagnostic(
      span = $x,
      message = "Order this range like a number line ‚Äî better: `lo < x && x < hi`"
    )
  },
  // between: `$lo < $x && $x > $hi`  (e.g. 1 < x && x > 0) ‚Äî second clause uses `>`
  `$lo < $x && $x > $hi` where {
    register_diagnostic(
      span = $x,
      message = "Order this range like a number line ‚Äî better: `lo < x && x < hi`"
    )
  },
  // between: `$hi > $x && $x < $lo`  (e.g. 10 > x && x < ...) ‚Äî first clause uses `>`
  `$hi > $x && $x < $lo` where {
    register_diagnostic(
      span = $x,
      message = "Order this range like a number line ‚Äî better: `lo < x && x < hi`"
    )
  },

  // ---------- INCLUSIVE between (`<=` / `>=`) ----------
  // Canonical inclusive `lo <= x && x <= hi` keeps bounds on the outside and
  // uses NO `>=`, so it is not matched by any branch below.
  // scrambled: `$x >= $lo && $x <= $hi`  (e.g. x >= 100 && x <= 599)
  `$x >= $lo && $x <= $hi` where {
    register_diagnostic(
      span = $x,
      message = "Order this range like a number line ‚Äî better: `lo < x && x < hi`"
    )
  },
  // scrambled (reordered): `$x <= $hi && $x >= $lo`  (e.g. x <= 9 && x >= 1)
  `$x <= $hi && $x >= $lo` where {
    register_diagnostic(
      span = $x,
      message = "Order this range like a number line ‚Äî better: `lo < x && x < hi`"
    )
  },
  // scrambled: `$lo <= $x && $x >= $hi` ‚Äî second clause uses `>=`
  `$lo <= $x && $x >= $hi` where {
    register_diagnostic(
      span = $x,
      message = "Order this range like a number line ‚Äî better: `lo < x && x < hi`"
    )
  },
  // scrambled: `$hi >= $x && $x <= $lo` ‚Äî first clause uses `>=`
  `$hi >= $x && $x <= $lo` where {
    register_diagnostic(
      span = $x,
      message = "Order this range like a number line ‚Äî better: `lo < x && x < hi`"
    )
  },

  // ---------- MIXED / HALF-OPEN between (one `<`/`<=`, one `>`/`>=`/flipped) ----------
  // scrambled: `$x >= $lo && $x < $hi`  (e.g. x >= 100 && x < 200)
  `$x >= $lo && $x < $hi` where {
    register_diagnostic(
      span = $x,
      message = "Order this range like a number line ‚Äî better: `lo < x && x < hi`"
    )
  },
  // scrambled (reordered): `$x < $hi && $x >= $lo`
  `$x < $hi && $x >= $lo` where {
    register_diagnostic(
      span = $x,
      message = "Order this range like a number line ‚Äî better: `lo < x && x < hi`"
    )
  },
  // scrambled: `$x > $lo && $x <= $hi`
  `$x > $lo && $x <= $hi` where {
    register_diagnostic(
      span = $x,
      message = "Order this range like a number line ‚Äî better: `lo < x && x < hi`"
    )
  },
  // scrambled (reordered): `$x <= $hi && $x > $lo`
  `$x <= $hi && $x > $lo` where {
    register_diagnostic(
      span = $x,
      message = "Order this range like a number line ‚Äî better: `lo < x && x < hi`"
    )
  },
  // scrambled: `$lo <= $x && $x > $hi` ‚Äî second clause uses `>`
  `$lo <= $x && $x > $hi` where {
    register_diagnostic(
      span = $x,
      message = "Order this range like a number line ‚Äî better: `lo < x && x < hi`"
    )
  },
  // scrambled: `$lo < $x && $x >= $hi` ‚Äî second clause uses `>=`
  `$lo < $x && $x >= $hi` where {
    register_diagnostic(
      span = $x,
      message = "Order this range like a number line ‚Äî better: `lo < x && x < hi`"
    )
  },
  // scrambled: `$hi >= $x && $x < $lo` ‚Äî first clause uses `>=`
  `$hi >= $x && $x < $lo` where {
    register_diagnostic(
      span = $x,
      message = "Order this range like a number line ‚Äî better: `lo < x && x < hi`"
    )
  },
  // scrambled: `$hi > $x && $x <= $lo` ‚Äî first clause uses `>`
  `$hi > $x && $x <= $lo` where {
    register_diagnostic(
      span = $x,
      message = "Order this range like a number line ‚Äî better: `lo < x && x < hi`"
    )
  },

  // ---------- STRICT outside (`||`) ----------
  // outside: `$x > $hi || $x < $lo`  (e.g. x > 10 || x < 1)
  `$x > $hi || $x < $lo` where {
    register_diagnostic(
      span = $x,
      message = "Order this range like a number line ‚Äî better: `x < lo || hi < x`"
    )
  },
  // outside: `$x < $lo || $x > $hi`  (e.g. x < 1 || x > 10)
  `$x < $lo || $x > $hi` where {
    register_diagnostic(
      span = $x,
      message = "Order this range like a number line ‚Äî better: `x < lo || hi < x`"
    )
  },
  // outside: `$hi < $x || $x < $lo`  (e.g. 10 < x || x < 1) ‚Äî first clause uses `<` with x on right
  `$hi < $x || $x < $lo` where {
    register_diagnostic(
      span = $x,
      message = "Order this range like a number line ‚Äî better: `x < lo || hi < x`"
    )
  },
  // outside: `$x > $hi || $lo > $x` ‚Äî reversed second clause; still teach shape
  `$x > $hi || $lo > $x` where {
    register_diagnostic(
      span = $x,
      message = "Order this range like a number line ‚Äî better: `x < lo || hi < x`"
    )
  },

  // ---------- INCLUSIVE / MIXED outside (`||` with `>=`/`<=`) ----------
  // Canonical inclusive outside `x <= lo || hi <= x` uses NO `>=` and keeps the
  // high bound on the LEFT of the second clause, so it is not matched below.
  // outside: `$x >= $hi || $x <= $lo`  (e.g. x >= 10 || x <= 1)
  `$x >= $hi || $x <= $lo` where {
    register_diagnostic(
      span = $x,
      message = "Order this range like a number line ‚Äî better: `x < lo || hi < x`"
    )
  },
  // outside: `$x <= $lo || $x >= $hi`  (e.g. x <= 1 || x >= 10)
  `$x <= $lo || $x >= $hi` where {
    register_diagnostic(
      span = $x,
      message = "Order this range like a number line ‚Äî better: `x < lo || hi < x`"
    )
  },
  // outside (reordered): `$hi <= $x || $x <= $lo` ‚Äî high-side test written first
  `$hi <= $x || $x <= $lo` where {
    register_diagnostic(
      span = $x,
      message = "Order this range like a number line ‚Äî better: `x < lo || hi < x`"
    )
  },
  // outside: `$x >= $hi || $lo >= $x` ‚Äî reversed second clause
  `$x >= $hi || $lo >= $x` where {
    register_diagnostic(
      span = $x,
      message = "Order this range like a number line ‚Äî better: `x < lo || hi < x`"
    )
  }
}
